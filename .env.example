# ============================================================
# .env.example — 실 값 채워서 .env로 저장 (절대 커밋 금지)
# INFRA-2D-1 / 운영 NCloud 기준
# ============================================================

# ── 앱 서버 ──
PORT=3000
NODE_ENV=production
TZ=Asia/Seoul

# ── 인증/암호화 (운영에서 강한 무작위값으로 교체 필수) ──
JWT_SECRET=CHANGE_ME_min32chars_random
ENC_SECRET=CHANGE_ME_exactly32chars_random!!

# ── 데이터베이스 ──
# Phase A(SQLite 유지): 아래 SQLite 라인 사용
DATABASE_URL=file:./data/hrmanage.db
DB_PATH=./data/hrmanage.db

# Phase B(PostgreSQL 전환): 아래 PG 라인으로 교체
# DATABASE_URL=postgresql://hrmanage_user:POSTGRES_PASSWORD@postgres:5432/hrmanage?schema=public

# ── PostgreSQL 컨테이너 ──
POSTGRES_DB=hrmanage
POSTGRES_USER=hrmanage_user
POSTGRES_PASSWORD=CHANGE_ME_strong_random_32chars

# ── certbot 이메일 (인증서 만료 알림 수신) ──
ADMIN_EMAIL=admin@synap.co.kr

# ── BL-005 이후: 시크릿 프로바이더 설정 추가 예정 ──
# SECRET_PROVIDER=env    # env | vault | aws-ssm | gcp-sm
# VAULT_ADDR=
# VAULT_TOKEN=

# ============================================================
# .env.example — 실 값 채워서 .env로 저장 (절대 커밋 금지)
# git clone 후 서버에서 직접 작성:
#   cp .env.example .env && nano .env
# ============================================================

# ── INFRA-2D 리허설 단계 (앱 없음, 지금 채울 항목) ──
DOMAIN=hrpms.synap.co.kr
CERTBOT_EMAIL=             # Let's Encrypt 만료 알림 이메일

POSTGRES_DB=hrmanage
POSTGRES_USER=hrmanage
POSTGRES_PASSWORD=         # 강한 무작위 32+ 문자 (예: openssl rand -base64 32)

TZ=Asia/Seoul

# ── Phase B 앱 착지 단계 (지금 채울 항목) ──

# 앱 시크릿 — compose env_file로 주입, compose.yml에 하드코딩 금지
JWT_SECRET=              # 최소 32자 무작위: openssl rand -base64 32
ENC_SECRET=              # 정확히 32바이트: openssl rand -hex 16
# ⚠️  ENC_SECRET 불변 원칙: 최초 설정 후 절대 변경 금지
#     변경 시 DB의 모든 암호화 필드 복호화 불가(데이터 손실)
#     운영 데이터가 있으면 안전 보관 필수. 테스트 서버는 fresh seed라 무관.

# DB 드라이버 (Phase B = PostgreSQL)
DB_DRIVER=postgres
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# PORT=3000  (compose.yml에서 주입)

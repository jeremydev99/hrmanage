# ============================================================
# .env.example — 실 값 채워서 .env로 저장 (절대 커밋 금지)
# git clone 후 서버에서 직접 작성:
#   cp .env.example .env && nano .env
# ============================================================

# ── INFRA-2D 리허설 단계 (앱 없음, 지금 채울 항목) ──
DOMAIN=hrpms.synap.co.kr
CERTBOT_EMAIL=             # Let's Encrypt 만료 알림 이메일

POSTGRES_DB=hrmanage
POSTGRES_USER=hrmanage
POSTGRES_PASSWORD=         # 강한 무작위 32+ 문자 (예: openssl rand -base64 32)

TZ=Asia/Seoul

# ── Phase B 앱 착지 단계에서 채울 항목 ──
# (아래는 Phase B에서 실 값으로 교체)

# JWT_SECRET=              # 최소 32자 무작위 (예: openssl rand -base64 32)
# ENC_SECRET=              # 정확히 32자 (예: openssl rand -hex 16)
#                          # ← BL-005에서 플러그블 시크릿 프로바이더로 이관 예정

# Phase A(SQLite 유지): 아래 SQLite 라인 사용 (현재 기본값)
# DATABASE_URL=file:./data/hrmanage.db
# DB_PATH=./data/hrmanage.db

# Phase B(PostgreSQL 전환): 아래 PG 라인으로 교체
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# PORT=3000
# NODE_ENV=production
